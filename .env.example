# Galvanize Agents — LLM and secrets
# Copy to .env and fill in values. For production, use GCP Secret Manager.

# Gemini (Google AI) — get key from https://aistudio.google.com/apikey
# Or use: gcloud secrets versions access latest --secret=galvanize-gemini-api-key --project=genuine-park-487014-a7
GOOGLE_API_KEY=

# Optional: OpenAI (for alternative LLM)
# OPENAI_API_KEY=

# Optional: Anthropic (for alternative LLM)
# ANTHROPIC_API_KEY=

# GCP project (for Secret Manager integration)
# GCP_PROJECT=genuine-park-487014-a7

# Optional: Serper (for Policy Monitor web search). Get key at https://serper.dev
# SERPER_API_KEY=
